<Window x:Class="QeliWin.QrShareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:QeliWin"
        Title="{l:Loc QrTitle}" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Bg}" FontFamily="{DynamicResource UiFont}">
    <StackPanel Margin="24">
        <TextBlock x:Name="HeaderText" Style="{StaticResource H1}" Margin="0,0,0,16"/>

        <Border Background="White" CornerRadius="12" Padding="14" HorizontalAlignment="Center">
            <Image x:Name="QrImage" Width="240" Height="240" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>

        <TextBox x:Name="LinkBox" IsReadOnly="True" Margin="0,16,0,0" FontFamily="Cascadia Mono, Consolas"
                 FontSize="11.5" TextWrapping="Wrap" VerticalContentAlignment="Top" MinHeight="56"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CopyBtn" Content="{l:Loc CopyLink}" Click="OnCopy" MinWidth="140" Margin="0,0,10,0"/>
            <Button Content="{l:Loc Close}" Click="OnClose" Style="{StaticResource AccentButton}" MinWidth="110"/>
        </StackPanel>
    </StackPanel>
</Window>
