<Window x:Class="QeliWin.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:QeliWin"
        Title="{l:Loc Profile}" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Bg}" FontFamily="{DynamicResource UiFont}">
    <Window.Resources>
        <Style TargetType="StackPanel" x:Key="Field">
            <Setter Property="Margin" Value="0,0,0,13"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="22">
        <Grid Margin="0,0,0,18">
            <TextBlock x:Name="HeaderText" Style="{StaticResource H1}" VerticalAlignment="Center"/>
            <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="OnManualEdit" ToolTip="{l:Loc ManualEdit}" Width="32" Height="32">
                <Viewbox Width="18" Height="18">
                    <Path Width="24" Height="24"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M9.4 16.6 4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0 4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                </Viewbox>
            </Button>
        </Grid>

        <StackPanel Style="{StaticResource Field}">
            <TextBlock Text="{l:Loc FieldName}" Style="{StaticResource Label}"/>
            <TextBox x:Name="NameBox"/>
        </StackPanel>

        <Grid Margin="0,0,0,13">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{l:Loc FieldServer}" Style="{StaticResource Label}"/>
                <TextBox x:Name="AddrBox"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{l:Loc FieldPort}" Style="{StaticResource Label}"/>
                <TextBox x:Name="PortBox" Text="443"/>
            </StackPanel>
        </Grid>

        <StackPanel Style="{StaticResource Field}">
            <TextBlock Text="{l:Loc FieldMode}" Style="{StaticResource Label}"/>
            <!-- One preset drives transport (proto), wire mode, obfs fronting and QUIC.
                 Switching a preset never changes the Port — the user sets it manually. -->
            <ComboBox x:Name="ModeBox" SelectionChanged="OnModeChanged">
                <ComboBoxItem Content="{l:Loc PresetFakeTls}" Tag="faketls"/>
                <ComboBoxItem Content="{l:Loc PresetObfsWs}" Tag="obfs-ws"/>
                <ComboBoxItem Content="{l:Loc PresetObfsNone}" Tag="obfs-none"/>
                <ComboBoxItem Content="{l:Loc PresetUdp}" Tag="udp"/>
                <ComboBoxItem Content="{l:Loc PresetUdpQuic}" Tag="udp-quic"/>
                <ComboBoxItem Content="{l:Loc PresetUdpObfs}" Tag="udp-obfs"/>
                <ComboBoxItem Content="{l:Loc PresetReality}" Tag="reality-tls"/>
                <ComboBoxItem Content="{l:Loc PresetPlain}" Tag="plain"/>
            </ComboBox>
        </StackPanel>

        <Grid Margin="0,0,0,13">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{l:Loc FieldLogin}" Style="{StaticResource Label}"/>
                <TextBox x:Name="UserBox"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{l:Loc FieldPassword}" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="PassBox"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="SniPanel" Style="{StaticResource Field}">
            <TextBlock Text="{l:Loc FieldSni}" Style="{StaticResource Label}"/>
            <ComboBox x:Name="SniBox" IsEditable="True" TextSearch.TextPath="Content">
                <ComboBoxItem Content="www.microsoft.com"/>
                <ComboBoxItem Content="www.cloudflare.com"/>
                <ComboBoxItem Content="www.apple.com"/>
                <ComboBoxItem Content="www.google.com"/>
                <ComboBoxItem Content="www.amazon.com"/>
            </ComboBox>
        </StackPanel>

        <Grid Margin="0,0,0,13">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{l:Loc FieldPadding}" Style="{StaticResource Label}"/>
                <ComboBox x:Name="PaddingBox">
                    <ComboBoxItem Content="{l:Loc Off}" Tag="off"/>
                    <ComboBoxItem Content="{l:Loc PaddingStandard}" Tag="0,255"/>
                    <ComboBoxItem Content="{l:Loc PaddingStrong}" Tag="40,400"/>
                    <ComboBoxItem Content="{l:Loc PaddingMax}" Tag="100,800"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{l:Loc FieldHeartbeat}" Style="{StaticResource Label}"/>
                <ComboBox x:Name="HeartbeatBox">
                    <ComboBoxItem Content="{l:Loc Off}" Tag="off"/>
                    <ComboBoxItem Content="{l:Loc Hb15}" Tag="15000,2000"/>
                    <ComboBoxItem Content="{l:Loc Hb30}" Tag="30000,5000"/>
                    <ComboBoxItem Content="{l:Loc Hb60}" Tag="60000,8000"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,13">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="ObfsKeyPanel" Grid.Column="0">
                <TextBlock Text="{l:Loc FieldObfsKey}" Style="{StaticResource Label}"/>
                <TextBox x:Name="ObfsKeyBox"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{l:Loc FieldServerKey}" Style="{StaticResource Label}"/>
                <TextBox x:Name="KeyBox"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="RealityIdPanel" Style="{StaticResource Field}">
            <TextBlock Text="{l:Loc FieldRealityId}" Style="{StaticResource Label}"/>
            <TextBox x:Name="RealityIdBox"/>
        </StackPanel>

        <Grid Margin="0,0,0,13">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{l:Loc FieldRouting}" Style="{StaticResource Label}"/>
                <ComboBox x:Name="RoutingBox">
                    <ComboBoxItem Content="{l:Loc RouteAll}" Tag="full-tunnel"/>
                    <ComboBoxItem Content="{l:Loc RouteSplit}" Tag="split-tunnel"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="MTU" Style="{StaticResource Label}"/>
                <ComboBox x:Name="MtuBox" IsEditable="True" TextSearch.TextPath="Content">
                    <ComboBoxItem Content="auto"/>
                    <ComboBoxItem Content="1500"/>
                    <ComboBoxItem Content="1400"/>
                    <ComboBoxItem Content="1280"/>
                    <ComboBoxItem Content="1200"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <StackPanel Style="{StaticResource Field}">
            <TextBlock Text="{l:Loc FieldDns}" Style="{StaticResource Label}"/>
            <ComboBox x:Name="DnsBox" IsEditable="True" TextSearch.TextPath="Content">
                <ComboBoxItem Content="1.1.1.1, 8.8.8.8"/>
                <ComboBoxItem Content="1.1.1.1, 1.0.0.1"/>
                <ComboBoxItem Content="8.8.8.8, 8.8.4.4"/>
                <ComboBoxItem Content="9.9.9.9, 149.112.112.112"/>
            </ComboBox>
        </StackPanel>

        <CheckBox x:Name="LocalBox" Content="{l:Loc RouteLocal}" Margin="0,2,0,4"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="{l:Loc Cancel}" Click="OnCancel" MinWidth="104" Margin="0,0,10,0"/>
            <Button Content="{l:Loc Save}" Click="OnSave" Style="{StaticResource AccentButton}" MinWidth="130"/>
        </StackPanel>
    </StackPanel>
</Window>
