<Window x:Class="QeliWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QeliWin"
        Title="Qeli — Quick Easy Link IP" Height="660" Width="980" MinHeight="560" MinWidth="860"
        Background="{DynamicResource Bg}" FontFamily="{DynamicResource UiFont}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:ReachabilityToBrushConverter x:Key="ReachConv"/>

        <Style x:Key="ProfileItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9" Padding="11,9">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Selected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatTile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="13,11"/>
        </Style>
        <Style x:Key="TileLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
        </Style>
        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="TileSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftCol" Width="340" MinWidth="280" MaxWidth="560"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- draggable splitter between the panels -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Background="Transparent"
                      Panel.ZIndex="10">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="Transparent"/>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ════ LEFT: brand + search + profiles ════ -->
        <DockPanel Grid.Column="0">
            <!-- brand band — height + the search below sum to the hero card height so
                 the hero's bottom edge lines up with the search field's bottom edge. -->
            <Grid DockPanel.Dock="Top" Height="48" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="LogoImage" Width="32" Height="32" Margin="0,0,11,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Qeli" FontFamily="{DynamicResource DisplayFont}" FontSize="19"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Fg}"/>
                        <TextBlock Text="Quick Easy Link IP" FontSize="11" Foreground="{DynamicResource FgDim}"/>
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="OnSettings" ToolTip="{local:Loc Settings}" Width="30" Height="30">
                    <Viewbox Width="17" Height="17">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                    </Viewbox>
                </Button>
            </Grid>

            <!-- search — fixed 40px so its bottom edge lines up with the hero card -->
            <Border DockPanel.Dock="Top" Height="40" Background="{DynamicResource InputBg}"
                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" CornerRadius="9" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- search magnifier -->
                    <Viewbox Grid.Column="0" Width="15" Height="15" Margin="11,0,0,0" VerticalAlignment="Center">
                        <Path Fill="{DynamicResource FgDim}"
                              Data="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0A4.5 4.5 0 1 1 14 9.5 4.5 4.5 0 0 1 9.5 14z"/>
                    </Viewbox>
                    <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0"
                             Padding="8,0" Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                             VerticalAlignment="Center" VerticalContentAlignment="Center" TextChanged="OnSearchChanged"/>
                    <!-- placeholder hides whenever the box has text OR keyboard focus, so
                         the caret never overlaps the hint (pure-XAML, no focus handlers) -->
                    <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="{local:Loc Search}"
                               IsHitTestVisible="False" Foreground="{DynamicResource FgDim}"
                               VerticalAlignment="Center" Margin="9,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button x:Name="ClearSearchBtn" Grid.Column="2" Style="{StaticResource IconButton}"
                            Width="26" Height="26" Margin="0,0,5,0" Click="OnClearSearch"
                            Content="✕" FontSize="12" Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- New / Import — height mirrors the log header bar on the right -->
            <Grid DockPanel.Dock="Bottom" Height="34" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="NewBtn" Grid.Column="0" Click="OnNew"
                        Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </Viewbox>
                        <TextBlock Text="{local:Loc New}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ImportBtn" Grid.Column="2" Click="OnImport" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                        </Viewbox>
                        <TextBlock Text="{local:Loc Import}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1" CornerRadius="12" Padding="6">
                <Grid>
                    <ListBox x:Name="ProfilesList" Style="{StaticResource SlimListBox}"
                             ItemContainerStyle="{StaticResource ProfileItem}"
                             SelectionChanged="OnProfileSelected">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Width="44" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse Width="9" Height="9" HorizontalAlignment="Center"
                                                 Fill="{Binding Reachability, Converter={StaticResource ReachConv}}"/>
                                        <TextBlock Text="{Binding LatencyText}" FontSize="9" Margin="0,3,0,0"
                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                   Foreground="{Binding Reachability, Converter={StaticResource ReachConv}}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Endpoint}" Foreground="{DynamicResource FgDim}"
                                                   FontSize="11.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28"
                                            Click="OnKebab" Content="⋯" FontSize="16" VerticalAlignment="Center">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{local:Loc Edit}" Click="OnMenuEdit"/>
                                                <MenuItem Header="{local:Loc Duplicate}" Click="OnMenuDuplicate"/>
                                                <MenuItem Header="{local:Loc ShareQr}" Click="OnMenuShare"/>
                                                <Separator/>
                                                <MenuItem Header="{local:Loc Delete}" Click="OnMenuDelete"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="EmptyHint" Text="{local:Loc NoProfilesHint}"
                               Foreground="{DynamicResource FgDim}" FontSize="13" TextAlignment="Center"
                               TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </DockPanel>

        <!-- ════ RIGHT: hero + stats + log (fills) ════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- hero: status + selected server + connect. Height = brand band + gap + search. -->
            <Border Grid.Row="0" Style="{StaticResource StatTile}" Height="102" Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- status halo -->
                    <Grid Grid.Column="0" Width="46" Height="46" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Ellipse Fill="{DynamicResource Hover}"/>
                        <Ellipse x:Name="StatusDot" Width="14" Height="14" HorizontalAlignment="Center"
                                 VerticalAlignment="Center" Fill="{DynamicResource StatusDisconnected}"/>
                        <Path x:Name="StatusSpinner" Width="22" Height="22" Visibility="Collapsed" StrokeThickness="2.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M11,2 A9,9 0 1 1 2,11"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform><RotateTransform x:Name="SpinnerRotate" Angle="0"/></Path.RenderTransform>
                        </Path>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="Disconnected" FontFamily="{DynamicResource DisplayFont}"
                                   FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Fg}"/>
                        <TextBlock x:Name="DetailText" Text="" Foreground="{DynamicResource FgDim}"
                                   FontSize="12.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Button x:Name="ConnectBtn" Grid.Column="2" Content="{local:Loc Connect}" Click="OnConnectToggle"
                            Style="{StaticResource AccentButton}" FontSize="14" Padding="26,11"
                            VerticalAlignment="Center" IsEnabled="False"/>
                </Grid>
            </Border>

            <!-- stat strip: one card, four metrics with a value + context sub-line -->
            <Border Grid.Row="1" Style="{StaticResource StatTile}" Padding="0" Margin="0,14,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="14,11">
                        <TextBlock x:Name="DownLabel" Style="{StaticResource TileLabel}"/>
                        <TextBlock x:Name="DownVal" Text="—" Style="{StaticResource TileValue}"/>
                        <TextBlock x:Name="TotalDownVal" Text="—" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{DynamicResource PanelBorder}" Margin="0,11"/>
                    <StackPanel Grid.Column="2" Margin="14,11">
                        <TextBlock x:Name="UpLabel" Style="{StaticResource TileLabel}"/>
                        <TextBlock x:Name="UpVal" Text="—" Style="{StaticResource TileValue}"/>
                        <TextBlock x:Name="TotalUpVal" Text="—" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <Border Grid.Column="3" Background="{DynamicResource PanelBorder}" Margin="0,11"/>
                    <StackPanel Grid.Column="4" Margin="14,11">
                        <TextBlock x:Name="SessionLabel" Style="{StaticResource TileLabel}"/>
                        <TextBlock x:Name="SessionVal" Text="—" Style="{StaticResource TileValue}"/>
                        <TextBlock x:Name="SessionSubVal" Text="" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <Border Grid.Column="5" Background="{DynamicResource PanelBorder}" Margin="0,11"/>
                    <StackPanel Grid.Column="6" Margin="14,11">
                        <TextBlock x:Name="IpLabel" Style="{StaticResource TileLabel}"/>
                        <TextBlock x:Name="IpVal" Text="—" Style="{StaticResource TileValue}" FontSize="15"/>
                        <TextBlock x:Name="IpSubVal" Text="" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- log — fills the remaining height; the most useful block grows with the window -->
            <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1" CornerRadius="12" Margin="0,14,0,0">
                <DockPanel>
                    <!-- header: title (left), copy/clear + version + about (right) -->
                    <Grid DockPanel.Dock="Top" Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc LogHeader}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Button Style="{StaticResource IconButton}" Click="OnCopyLog" ToolTip="{local:Loc LogCopy}"
                                    Width="26" Height="26">
                                <Viewbox Width="15" Height="15">
                                    <Path Width="24" Height="24" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M16 1H4C2.9 1 2 1.9 2 3v14h2V3h12V1zm3 4H8C6.9 5 6 5.9 6 7v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource IconButton}" Click="OnClearLog" ToolTip="{local:Loc LogClear}"
                                    Width="26" Height="26">
                                <Viewbox Width="15" Height="15">
                                    <Path Width="24" Height="24" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                </Viewbox>
                            </Button>
                            <TextBlock x:Name="VersionText" Foreground="{DynamicResource FgDim}" FontSize="12"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBlock x:Name="UpdateText" Foreground="{DynamicResource Fg}" FontSize="12"
                                       FontWeight="SemiBold" TextDecorations="Underline" Cursor="Hand"
                                       VerticalAlignment="Center" Margin="0,0,6,0" Visibility="Collapsed"
                                       MouseLeftButtonUp="OnUpdateClick" ToolTip="{local:Loc UpdateOpenPage}"/>
                            <Button Style="{StaticResource IconButton}" Click="OnAbout" ToolTip="{local:Loc About}"
                                    Width="26" Height="26">
                                <Viewbox Width="15" Height="15">
                                    <Path Width="24" Height="24" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M11 7h2v2h-2zm0 4h2v6h-2zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Margin="1,0,1,1">
                        <TextBox x:Name="LogBox" Background="Transparent" Foreground="{DynamicResource FgDim}"
                                 BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="12" IsReadOnly="True"
                                 Padding="12,8" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
