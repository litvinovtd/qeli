# ── Secrets / per-deployment creds — NEVER commit ──
keystore.properties
*.jks
*.keystore
scripts/lab_env.sh
scripts/.lab_secrets
# Real deployment configs (only *placeholder* templates are tracked; fill copies locally)
release/reality-tls/*-prod.conf
*.local.conf
/etc/qeli/
# Prod secrets / per-deployment artifacts — generated, contain creds/keys/links
release/prod-allmodes-secrets.json
release/prod-allmodes-pubkeys.json
release/prod-server-allmodes.conf
release/prod-maxobf-migrated.conf
release/prod-client-configs/

# ── Private (not for GitHub) ──
site/
site.zip

# ── Obsolete one-off ops/debug scripts (kept locally only) ──
scripts/archive/

# ── Build artifacts / distributables (use GitHub Releases, not git) ──
release/dist/
release/*.apk
release/*.deb
release/qeli-linux-amd64
# Keenetic cross-built binaries (шаблоны деплоя в release/keenetic/ — трекаем, бинари — нет)
release/keenetic/qeli-client-*

# ── Web-panel asset build (Node) — generated app.css is committed under
#    qeli/src/web/assets/; node_modules is not. ──
qeli/web-assets/node_modules/

# ── Python caches ──
__pycache__/
*.pyc

# ── Rust build ──
target/
**/target/

# cargo-fuzz generated corpus / crash artifacts (the harnesses in qeli/fuzz are
# tracked; their inputs/outputs are not — see qeli/fuzz/README.md)
qeli/fuzz/corpus/
qeli/fuzz/artifacts/
qeli/fuzz/coverage/

# ── .NET client build output ──
**/obj/
**/bin/
qeli-win/dist/
qeli-mac/dist/
# `dotnet publish` output dirs (per-project) — large build artifacts, publish via Releases
qeli-win/QeliWin/dist/
qeli-mac/QeliMac/dist-publish/
**/dist-publish/
# NB: committed native cores (jniLibs/*.so, QeliWin/native/qeli.dll,
# QeliMac/native/libqeli.dylib) are INTENTIONALLY tracked — do not ignore them.

# ── Android build ──
qeli-android/.gradle/
qeli-android/build/
qeli-android/app/build/
qeli-android/local.properties
qeli-android/dist/
# Gradle distribution zip (downloaded by the wrapper — keep gradle-wrapper.jar, not this)
qeli-android/gradle-*-bin.zip
*-bin.zip

# ── Misc ──
*.log
.DS_Store
Thumbs.db

# ── Release-prep hardening (0.6.0) ──
# Local per-deployment client configs (may hold creds; templates client.conf/server.conf stay tracked)
qeli/config/client-*.conf
# Stray feature-build server binaries (publish via GitHub Releases)
release/qeli-*-amd64
# Stray debug APKs in the android root
qeli-android/*.apk
