<?xml version="1.0" encoding="utf-8"?>
<!-- Selected-segment pill for the segmented tab control. Drawn behind the active
     tab (indicator gravity = stretch) so it reads as a white pill inside the
     grey track. Inset keeps a small gap from the track edges. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="4dp"
    android:insetRight="4dp"
    android:insetTop="4dp"
    android:insetBottom="4dp">
    <shape android:shape="rectangle">
        <solid android:color="@color/surface" />
        <corners android:radius="13dp" />
        <stroke android:width="1dp" android:color="@color/outline" />
    </shape>
</inset>
