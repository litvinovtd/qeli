<?xml version="1.0" encoding="utf-8"?>
<!--
  Languages the app ships. Declaring them lets Android 13+ list qeli under
  Settings → System → Languages → App languages; on API 28–32 androidx.appcompat
  backports the same per-app locale via AppCompatDelegate.setApplicationLocales.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en"/>
    <locale android:name="ru"/>
</locale-config>
