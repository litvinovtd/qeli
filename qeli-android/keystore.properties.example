# Template for release APK signing. Copy to `keystore.properties` (which is
# git-ignored) and fill in real values. Without keystore.properties, release
# builds are left unsigned.
#
# 1) Generate a release keystore once (keep it + these passwords safe — losing
#    them means you can never update the app under the same identity):
#
#    keytool -genkeypair -v \
#      -keystore qeli-release.jks \
#      -alias qeli \
#      -keyalg RSA -keysize 4096 -validity 10000
#
# 2) Copy this file to keystore.properties and set the four values below.
# 3) Build: ./gradlew assembleRelease  (now signed)

storeFile=qeli-release.jks
storePassword=CHANGE_ME
keyAlias=qeli
keyPassword=CHANGE_ME
