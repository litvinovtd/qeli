#!/bin/sh /etc/rc.common
# procd service for the qeli VPN client on OpenWrt.
#   /etc/init.d/qeli {start|stop|restart|reload|enable|status}
# Config lives in UCI (/etc/config/qeli) or LuCI — this script renders it to a
# 0600 flat-INI in tmpfs and runs `qeli client` under procd (respawn + logread).

USE_PROCD=1
START=99
STOP=10

BIN=/usr/bin/qeli-client        # client-only binary (src/client_main.rs); run directly with --config
RUNDIR=/var/run/qeli            # tmpfs — the RENDERED INI never hits flash. NOTE: the UCI
                                # source /etc/config/qeli still holds pass/obfs_key in
                                # plaintext on flash (mode 0600); tmpfs only spares the copy.
CONF="$RUNDIR/client.conf"
STATEDIR=/etc/qeli              # persistent overlay — device-id + TOFU known_hosts survive reboot

# Strip CR/LF (and every other control character) from a UCI value.
#
# UCI values here are attacker-influenced: the LuCI ACL grants write access to the
# whole `qeli` package, so anyone who reaches the LuCI RPC can set them. Written
# verbatim into a flat-INI file, one embedded newline becomes a SECOND key — and the
# keys that matter are `post_up` / `post_down` / `password_command`, which the client
# runs through `sh -c`. This service runs as root under procd and the generated file
# passes the "trusted config" check (mode 0600), so a smuggled line would run as root.
#
# Whether a raw LF survives libuci's line-oriented parser is doubtful — in practice it
# more likely corrupts /etc/config/qeli and bricks the package for every reader.
# Neither outcome is acceptable, and this costs one `tr`.
ini_sanitize() { printf '%s' "$1" | tr -d '\000-\037'; }

# Append `key = value` to the INI only when value is non-empty.
ini_kv() { [ -n "$2" ] && printf '%s = %s\n' "$1" "$(ini_sanitize "$2")" >> "$CONF"; }

# Render the UCI `main` section into the flat-INI the binary expects.
render_conf() {
	local server proto user pass key bind_static mode sni obfs_key front quic \
	      reality_sid gateway dns dev mtu route_local kill_switch allow_ipv6_leak log_level \
	      log_time_format

	config_get server     main server
	config_get proto      main proto      tcp
	config_get user       main user
	config_get pass       main pass
	config_get key        main key
	config_get_bool bind_static main bind_static 1   # H-1 on by default (needs a pinned key)
	config_get mode       main mode       fake-tls
	config_get sni        main sni
	config_get obfs_key   main obfs_key
	config_get front      main front
	config_get_bool quic  main quic       0
	config_get reality_sid main reality_sid
	config_get_bool gateway main gateway   0          # 0 = split-tunnel (safe default)
	config_get dns        main dns        off
	config_get dev        main dev        qeli0
	config_get mtu        main mtu        0
	config_get_bool route_local main route_local 0
	config_get_bool kill_switch main kill_switch 0
	config_get_bool allow_ipv6_leak main allow_ipv6_leak 0
	config_get log_level  main log_level  info
	# `none` by default: procd pipes stderr to syslog, which stamps every line —
	# an app timestamp on top of that is duplicated noise in `logread`.
	config_get log_time_format main log_time_format none

	[ -n "$server" ] || { logger -t qeli "ERROR: option 'server' is not set in /etc/config/qeli"; return 1; }

	mkdir -p "$RUNDIR"; : > "$CONF"; chmod 600 "$CONF"
	{
		echo "[qeli]"
		echo "server = $(ini_sanitize "$server")"
		echo "proto = $(ini_sanitize "$proto")"
	} >> "$CONF"
	ini_kv user "$user"
	ini_kv pass "$pass"
	ini_kv key  "$key"
	# bind_static is on by default; only emit when explicitly off (TOFU / zero key).
	[ "$bind_static" = 0 ] && echo "bind_static = false" >> "$CONF"
	ini_kv mode "$mode"
	ini_kv sni  "$sni"
	ini_kv obfs_key "$obfs_key"
	ini_kv front "$front"
	[ "$quic" = 1 ] && echo "quic = true" >> "$CONF"
	ini_kv reality_sid "$reality_sid"
	# Routing: full-tunnel only on explicit opt-in (`gateway = false` => split).
	[ "$gateway" = 1 ] && echo "gateway = true" >> "$CONF" || echo "gateway = false" >> "$CONF"
	ini_kv dns "$dns"
	ini_kv dev "$dev"
	[ "$mtu" -gt 0 ] 2>/dev/null && echo "mtu = $mtu" >> "$CONF"
	[ "$route_local" = 1 ] && echo "route_local = true" >> "$CONF"
	[ "$kill_switch" = 1 ] && echo "kill_switch = true" >> "$CONF"
	# Full tunnel blackholes IPv6 (qeli carries IPv4 only), and refuses to connect if
	# it cannot. On a build without IPv6 routing support that would make the tunnel
	# unusable with no way out, so expose the escape hatch here too.
	[ "$allow_ipv6_leak" = 1 ] && echo "allow_ipv6_leak = true" >> "$CONF"
	# Sanitize log_level like every other value: a control char in the UCI option
	# (e.g. a stray newline) would otherwise inject an extra INI line here. (C-10)
	printf '\n[logging]\nlevel = %s\ntime_format = %s\n' \
		"$(ini_sanitize "$log_level")" "$(ini_sanitize "$log_time_format")" >> "$CONF"
	return 0
}

# Keep the `qeli` firewall zone pointing at the CURRENT tun device.
#
# The zone is created once at install (qeli.firewall.uci-defaults) from whatever
# `qeli.main.dev` was then. Changing `dev` afterwards — in LuCI or by hand — left the zone
# matching the OLD interface, so masquerading and the lan→qeli forwarding silently stopped
# applying: the tunnel comes up, the router says everything is fine, and the LAN simply
# stops reaching the internet through it. Re-checked on every start, and only written when
# it actually differs (a no-op start must not commit UCI or bounce the firewall). (C-25)
sync_firewall_device() {
	local dev zone cur
	dev="$(uci -q get qeli.main.dev || echo qeli0)"

	zone=""
	find_zone() { [ "$(uci -q get firewall.$1.name)" = "qeli" ] && zone="$1"; }
	config_load firewall
	config_foreach find_zone zone
	config_load qeli          # restore the config context start_service is reading
	[ -n "$zone" ] || return 0   # no zone (gateway mode not set up) — nothing to sync

	# `device` is a list; treat "exactly our dev and nothing else" as already correct.
	cur="$(uci -q get firewall.$zone.device)"
	[ "$cur" = "$dev" ] && return 0

	uci -q delete firewall."$zone".device
	uci add_list firewall."$zone".device="$dev"
	uci commit firewall
	logger -t qeli "firewall zone 'qeli': device ${cur:-<unset>} -> $dev (re-synced from uci)"
	[ -x /etc/init.d/firewall ] && /etc/init.d/firewall reload >/dev/null 2>&1
	return 0
}

start_service() {
	config_load qeli

	local enabled
	config_get_bool enabled main enabled 0
	[ "$enabled" = 1 ] || { logger -t qeli "service disabled (uci set qeli.main.enabled=1)"; return 0; }

	[ -x "$BIN" ] || { logger -t qeli "ERROR: $BIN missing"; return 1; }
	[ -e /dev/net/tun ] || { logger -t qeli "ERROR: /dev/net/tun missing — install kmod-tun"; return 1; }

	render_conf || return 1
	mkdir -p "$STATEDIR"
	sync_firewall_device

	procd_open_instance qeli
	procd_set_param command "$BIN" --config "$CONF"
	# Persistent identity/pinning across reboots (/etc and overlay survive; /var is tmpfs).
	procd_set_param env QELI_DEVICE_ID_FILE="$STATEDIR/device-id" QELI_KNOWN_HOSTS="$STATEDIR/known_hosts"
	procd_set_param respawn 3600 5 0      # respawn: threshold 3600s, 5s delay, unlimited
	procd_set_param stdout 1              # → logread -e qeli
	procd_set_param stderr 1
	procd_set_param pidfile "$RUNDIR/qeli.pid"
	# Re-render + restart when the UCI config changes.
	procd_add_reload_trigger qeli
	procd_close_instance
	logger -t qeli "started (server from uci, dev $(uci -q get qeli.main.dev || echo qeli0))"
}

stop_service() {
	rm -f "$CONF"
}

reload_service() {
	restart
}

service_triggers() {
	procd_add_reload_trigger qeli
}
